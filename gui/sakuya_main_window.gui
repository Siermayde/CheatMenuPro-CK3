window = {
	name = "sakuya_guiname_main_window"
	parentanchor = center
	position = { 0 0 }
	size = { 1280 720 }
	movable = yes
	layer = windows_layer
	allow_outside = yes
	filter_mouse = all

	visible = "[GetVariableSystem.Exists('sakuya_main_visible')]"
	enabled = "[GetVariableSystem.Exists('sakuya_main_visible')]"

	using = Animation_ShowHide_Standard
	state = { name = _show alpha = 1 duration = 0.2 using = Animation_Curve_Default }
	state = { name = _hide alpha = 0 duration = 0.2 using = Animation_Curve_Default }

	widget = {
		name = "sakuya_guiname_main_root" 
		size = { 1280 720 }

		icon = {
			size = { 1280 720 }
			texture = "gfx/interface/sakuya/main/sakuya_main_bk.png"
		}

		icon = {
			position = { 20 25 }
			size = { 1240 684 }
			texture = "gfx/interface/component_overlay/overlay_thin_frame.dds"
			spriteType = Corneredstretched
			spriteborder = { 15 15 }
			texture_density = 2
			alpha = 0.78
		}

		textbox = {
			name = "sakuya_guiname_main_title"
			parentanchor = top|hcenter
			position = { 0 50 }
			size = { 620 52 }
			maximumsize = { 620 52 }
			text = "sakuya_main_title_text"
			font = "MapFont"
			fontsize = 38
			fontsize_min = 24
			autoresize = no
			align = center|nobaseline
			default_format = "#COLOR:{0.639,0.581,0.492,1};bold;glow_color:{0,0,0,0.85}"
		}

		button_standard = {
			name = "sakuya_guiname_main_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[GetVariableSystem.HasValue('sakuya_tab', 'title')]"
			onclick = "[GetVariableSystem.Set('sakuya_p2_transition', 'active')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_dynasty_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			tooltip = "sakuya_main_back_tt"
			text_single = {
				parentanchor = center
				text = "sakuya_main_back_text"
				fontsize = 16
				fontsize_min = 10
				autoresize = no
				align = center|nobaseline
			}
		}

		button_standard = {
			name = "sakuya_guiname_main_character_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[And(GetVariableSystem.HasValue('sakuya_tab', 'character'), Not(GetVariableSystem.Exists('sakuya_character_page_transition')))]"
			onclick = "[GetVariableSystem.Clear('sakuya_character_bookmark_hover')]"
			onclick = "[PdxGuiTriggerAllAnimations('bookmark_hover_conceal')]"
			onclick = "[GetVariableSystem.Set('sakuya_character_page_transition', 'active')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_dynasty_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('enter_subpage','return_home_after_bookmarks')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_page_character_title').InterruptThenTriggerAnimation('page_enter','page_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_page_character_content').InterruptThenTriggerAnimation('page_enter','page_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_1').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_2').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_3').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_4').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_5').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_6').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_row_7').InterruptThenTriggerAnimation('bookmark_enter','bookmark_exit')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			tooltip = "sakuya_main_back_tt"
			text_single = { parentanchor = center text = "sakuya_main_back_text" fontsize = 16 fontsize_min = 10 autoresize = no align = center|nobaseline }
		}

		button_standard = {
			name = "sakuya_guiname_main_dynasty_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[And(GetVariableSystem.HasValue('sakuya_tab', 'dynasty'), Not(GetVariableSystem.Exists('sakuya_p3_transition')))]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Set('sakuya_p3_transition', 'active')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_dynasty_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			tooltip = "sakuya_main_back_tt"
			text_single = {
				parentanchor = center
				text = "sakuya_main_back_text"
				fontsize = 16
				fontsize_min = 10
				autoresize = no
				align = center|nobaseline
			}
		}

		button_close = {
			name = "sakuya_guiname_main_close_button"
			parentanchor = top|right
			position = { -18 18 }
			size = { 30 30 }
			tooltip = "sakuya_main_close_tt"
			onclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Clear('sakuya_p2_transition')]"
			onclick = "[GetVariableSystem.Clear('sakuya_p3_transition')]"
			onclick = "[GetVariableSystem.Clear('sakuya_character_page_transition')]"
			onclick = "[GetVariableSystem.Clear('sakuya_character_bookmark_hover')]"
			onclick = "[PdxGuiTriggerAllAnimations('bookmark_hover_conceal')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_p2_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_p3_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_character_page_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_character_bookmark_hover')]"
			onrightclick = "[PdxGuiTriggerAllAnimations('bookmark_hover_conceal')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			shortcut = "close_window"
		}

		# Drawn before the card container so the card frame covers each ribbon root.
		widget = {
			name = "sakuya_guiname_character_bookmark_navigation"
			# Active card frame right edge is x=390; 345 + 100 - 390 = 55 px, i.e. 46 * 1.2 rounded.
			position = { 345 182 }
			size = { 390 370 }
			allow_outside = yes
			visible = "[Or(GetVariableSystem.HasValue('sakuya_tab', 'character'), GetVariableSystem.Exists('sakuya_character_page_transition'))]"
			vbox = {
				size = { 390 370 }
				spacing = 8
				ignoreinvisible = yes

				widget = {
					size = { 390 46 }
					allow_outside = yes
					widget = {
						name = "sakuya_guiname_character_bookmark_row_1"
						position = { -90 0 }
						size = { 390 46 }
						alpha = 0.01
						allow_outside = yes
						state = {
							name = bookmark_enter
							position_x = 0
							alpha = 1
							delay = 0.16
							duration = 0.09
							using = Animation_Curve_Default
						}
						state = {
							name = bookmark_exit
							position_x = -90
							alpha = 0.01
							delay = 0.28
							duration = 0.09
							using = Animation_Curve_Default
							on_finish = "[GetVariableSystem.Clear('sakuya_character_page_transition')]"
						}
						widget = {
							name = "sakuya_guiname_character_bookmark_hover_shift_1"
							size = { 390 46 }
							allow_outside = yes
							icon = {
								size = { 100 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								visible = "[Not(GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1'))]"
								alwaystransparent = yes
							}

							# 45 px remain under the active card frame; 119 - 45 = 74 px, the nearest whole-pixel 46 * 1.618 length.
							icon = {
								size = { 119 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1')]"
								alwaystransparent = yes
							}

							button = {
								name = "sakuya_guiname_character_bookmark_visual_1"
								minimumsize = { 119 46 }
								maximumsize = { 373 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								alwaystransparent = yes
								enabled = "[And(GetVariableSystem.HasValue('sakuya_tab', 'character'), Not(GetVariableSystem.Exists('sakuya_character_page_transition')))]"
								modify_texture = {
									name = "bookmark_reveal"
									texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
									blend_mode = alphaMultiply
									translate_uv = { -1 0 }
									alpha = 1
								}
								glow = {
									glow_radius = 4
									color = { 0.85 0.42 0.18 1 }
									using = Glow_Standard
									alpha = 0
								}
								state = {
									name = bookmark_hover_reveal
									duration = 0.16
									using = Animation_Curve_Default
									glow_alpha = 0.66
									modify_texture = {
										name = "bookmark_reveal"
										translate_uv = { 1 0 }
									}
								}
								state = {
									name = bookmark_hover_conceal
									duration = 0.16
									using = Animation_Curve_Default
									glow_alpha = 0
									modify_texture = {
										name = "bookmark_reveal"
										translate_uv = { -1 0 }
									}
								}
								flowcontainer = {
									resizeparent = yes
									margin_left = 100
									margin_right = 28
									margin_top = 9
									margin_bottom = 9
									spacing = 8

									text_single = {
										visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark_hover', 'item_1')]"
										text = "sakuya_character_bookmark_1_text"
										fontsize = 20
										fontsize_min = 14
										autoresize = yes
										max_width = 245
										align = nobaseline
										default_format = "#high;bold"
										alwaystransparent = yes
									}
								}
							}

							# Draw selection VFX and slot icon after the button so the expanded ribbon cannot cover them.
							icon = {
								name = "sakuya_guiname_character_bookmark_selected_glow_1"
								position = { 54 -5 }
								size = { 56 56 }
								texture = "gfx/interface/component_masks/mask_glow.dds"
								color = { 1.00 0.78 0.48 0.40 }
								alpha = 0.32
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1')]"
								alwaystransparent = yes
							}

							icon_flat_standard_gold = {
								name = "sakuya_guiname_character_bookmark_icon_1"
								position = { 57 7 }
								size = { 32 32 }
								texture = "gfx/interface/icons/flat_icons/star.dds"
								visible = "[Not(GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1'))]"
								alwaystransparent = yes
							}

							icon_flat_standard_gold = {
								name = "sakuya_guiname_character_bookmark_icon_selected_1"
								position = { 66 7 }
								size = { 32 32 }
								texture = "gfx/interface/icons/flat_icons/star.dds"
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1')]"
								alwaystransparent = yes
							}

							# Only the collapsed tab is interactive. The expanded ribbon above is visual and mouse-transparent.
							button = {
								name = "sakuya_guiname_character_bookmark_input_1"
								size = { 100 46 }
								visible = "[Not(GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1'))]"
								enabled = "[And(GetVariableSystem.HasValue('sakuya_tab', 'character'), Not(GetVariableSystem.Exists('sakuya_character_page_transition')))]"
								alwaystransparent = no
								onclick = "[PdxGuiTriggerAllAnimations('sakuya_character_title_select_1')]"
								onmousehierarchyenter = "[GetVariableSystem.Set('sakuya_character_bookmark_hover', 'item_1')]"
								onmousehierarchyenter = "[PdxGuiTriggerAllAnimations('bookmark_hover_conceal')]"
								onmousehierarchyenter = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_visual_1').InterruptThenTriggerAnimation('bookmark_hover_conceal','bookmark_hover_reveal')]"
								onmousehierarchyleave = "[GetVariableSystem.Clear('sakuya_character_bookmark_hover')]"
								onmousehierarchyleave = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_visual_1').InterruptThenTriggerAnimation('bookmark_hover_reveal','bookmark_hover_conceal')]"
							}

							button = {
								name = "sakuya_guiname_character_bookmark_input_selected_1"
								size = { 119 46 }
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_1')]"
								enabled = "[And(GetVariableSystem.HasValue('sakuya_tab', 'character'), Not(GetVariableSystem.Exists('sakuya_character_page_transition')))]"
								alwaystransparent = no
								onclick = "[PdxGuiTriggerAllAnimations('sakuya_character_title_select_1')]"
								onmousehierarchyenter = "[GetVariableSystem.Set('sakuya_character_bookmark_hover', 'item_1')]"
								onmousehierarchyenter = "[PdxGuiTriggerAllAnimations('bookmark_hover_conceal')]"
								onmousehierarchyenter = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_visual_1').InterruptThenTriggerAnimation('bookmark_hover_conceal','bookmark_hover_reveal')]"
								onmousehierarchyleave = "[GetVariableSystem.Clear('sakuya_character_bookmark_hover')]"
								onmousehierarchyleave = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_character_bookmark_visual_1').InterruptThenTriggerAnimation('bookmark_hover_reveal','bookmark_hover_conceal')]"
							}
						}
					}
				}

				widget = {
					size = { 390 46 }
					allow_outside = yes
					widget = {
						name = "sakuya_guiname_character_bookmark_row_2"
						position = { -90 0 }
						size = { 390 46 }
						alpha = 0.01
						allow_outside = yes
						state = {
							name = bookmark_enter
							position_x = 0
							alpha = 1
							delay = 0.18
							duration = 0.09
							using = Animation_Curve_Default
						}
						state = {
							name = bookmark_exit
							position_x = -90
							alpha = 0.01
							delay = 0.26
							duration = 0.09
							using = Animation_Curve_Default
						}
						widget = {
							name = "sakuya_guiname_character_bookmark_hover_shift_2"
							size = { 390 46 }
							allow_outside = yes
							icon = {
								size = { 100 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								visible = "[Not(GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_2'))]"
								alwaystransparent = yes
							}

							# 45 px remain under the active card frame; 119 - 45 = 74 px, the nearest whole-pixel 46 * 1.618 length.
							icon = {
								size = { 119 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_2')]"
								alwaystransparent = yes
							}

							button = {
								name = "sakuya_guiname_character_bookmark_visual_2"
								minimumsize = { 119 46 }
								maximumsize = { 373 46 }
								texture = "gfx/interface/sakuya/slik_right.png"
								spriteType = Corneredstretched
								spriteborder = { 55 0 }
								spriteborder_right = 24
								alwaystransparent = yes
								enabled = "[And(GetVariableSystem.HasValue('sakuya_tab', 'character'), Not(GetVariableSystem.Exists('sakuya_character_page_transition')))]"
								modify_texture = {
									name = "bookmark_reveal"
									texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
									blend_mode = alphaMultiply
									translate_uv = { -1 0 }
									alpha = 1
								}
								glow = {
									glow_radius = 4
									color = { 0.85 0.42 0.18 1 }
									using = Glow_Standard
									alpha = 0
								}
								state = {
									name = bookmark_hover_reveal
									duration = 0.16
									using = Animation_Curve_Default
									glow_alpha = 0.66
									modify_texture = {
										name = "bookmark_reveal"
										translate_uv = { 1 0 }
									}
								}
								state = {
									name = bookmark_hover_conceal
									duration = 0.16
									using = Animation_Curve_Default
									glow_alpha = 0
									modify_texture = {
										name = "bookmark_reveal"
										translate_uv = { -1 0 }
									}
								}
								flowcontainer = {
									resizeparent = yes
									margin_left = 100
									margin_right = 28
									margin_top = 9
									margin_bottom = 9
									spacing = 8

									text_single = {
										visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark_hover', 'item_2')]"
										text = "sakuya_character_bookmark_2_text"
										fontsize = 20
										fontsize_min = 14
										autoresize = yes
										max_width = 245
										align = nobaseline
										default_format = "#high;bold"
										alwaystransparent = yes
									}
								}
							}

							# Draw selection VFX and slot icon after the button so the expanded ribbon cannot cover them.
							icon = {
								name = "sakuya_guiname_character_bookmark_selected_glow_2"
								position = { 54 -5 }
								size = { 56 56 }
								texture = "gfx/interface/component_masks/mask_glow.dds"
								color = { 1.00 0.78 0.48 0.40 }
								alpha = 0.32
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_2')]"
								alwaystransparent = yes
							}

							icon_flat_standard_gold = {
								name = "sakuya_guiname_character_bookmark_icon_2"
								position = { 57 7 }
								size = { 32 32 }
								texture = "gfx/interface/icons/flat_icons/star.dds"
								visible = "[Not(GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_2'))]"
								alwaystransparent = yes
							}

							icon_flat_standard_gold = {
								name = "sakuya_guiname_character_bookmark_icon_selected_2"
								position = { 66 7 }
								size = { 32 32 }
								texture = "gfx/interface/icons/flat_icons/star.dds"
								visible = "[GetVariableSystem.HasValue('sakuya_character_bookmark', 'item_2')]"
								alwaystransparent = yes
							}

							# Only the collapsed tab is interactive. The expanded ribbon above is visual and mouse-transparent.
							button = {
								name = "sakuya_guiname_character_bookmark_input_2"
