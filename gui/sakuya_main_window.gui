window = {
	name = "sakuya_guiname_main_window"
	parentanchor = center
	position = { 0 0 }
	size = { 1280 720 }
	movable = yes
	layer = windows_layer
	allow_outside = yes
	filter_mouse = all

	visible = "[GetVariableSystem.Exists('sakuya_main_visible')]"
	enabled = "[GetVariableSystem.Exists('sakuya_main_visible')]"

	using = Animation_ShowHide_Standard
	state = { name = _show alpha = 1 duration = 0.2 using = Animation_Curve_Default }
	state = { name = _hide alpha = 0 duration = 0.2 using = Animation_Curve_Default }

	widget = {
		name = "sakuya_guiname_main_root" 
		size = { 1280 720 }

		icon = {
			size = { 1280 720 }
			texture = "gfx/interface/sakuya/main/sakuya_main_bk.png"
		}

		icon = {
			position = { 20 25 }
			size = { 1240 684 }
			texture = "gfx/interface/component_overlay/overlay_thin_frame.dds"
			spriteType = Corneredstretched
			spriteborder = { 15 15 }
			texture_density = 2
			alpha = 0.78
		}

		textbox = {
			name = "sakuya_guiname_main_title"
			parentanchor = top|hcenter
			position = { 0 50 }
			size = { 620 52 }
			maximumsize = { 620 52 }
			text = "sakuya_main_title_text"
			font = "MapFont"
			fontsize = 38
			fontsize_min = 24
			autoresize = no
			align = center|nobaseline
			default_format = "#COLOR:{0.639,0.581,0.492,1};bold;glow_color:{0,0,0,0.85}"
		}

		button_standard = {
			name = "sakuya_guiname_main_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[And(GetVariableSystem.Exists('sakuya_tab'), Not(GetVariableSystem.HasValue('sakuya_tab', 'dynasty')))]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_dynasty_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			tooltip = "sakuya_main_back_tt"
			text_single = {
				parentanchor = center
				text = "sakuya_main_back_text"
				fontsize = 16
				fontsize_min = 10
				autoresize = no
				align = center|nobaseline
			}
		}

		button_standard = {
			name = "sakuya_guiname_main_dynasty_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[And(GetVariableSystem.HasValue('sakuya_tab', 'dynasty'), Not(GetVariableSystem.Exists('sakuya_p3_transition')))]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Set('sakuya_p3_transition', 'active')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p2_title_card').InterruptThenTriggerAnimation('fade_out_other','restore_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_dynasty_card').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_home_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p3_subpage_title').InterruptThenTriggerAnimation('enter_subpage','return_home')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			tooltip = "sakuya_main_back_tt"
			text_single = {
				parentanchor = center
				text = "sakuya_main_back_text"
				fontsize = 16
				fontsize_min = 10
				autoresize = no
				align = center|nobaseline
			}
		}

		button_close = {
			name = "sakuya_guiname_main_close_button"
			parentanchor = top|right
			position = { -18 18 }
			size = { 30 30 }
			tooltip = "sakuya_main_close_tt"
			onclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onclick = "[GetVariableSystem.Clear('sakuya_p3_transition')]"
			onclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_p3_transition')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
			shortcut = "close_window"
		}

		widget = {
			name = "sakuya_guiname_main_home_cards"
			position = { 58 137 }
			size = { 1164 507 }
			allow_outside = yes
			widget = {
				name = "sakuya_guiname_main_p1_character_card"
				position = { 55 0 }
				size = { 315 507 }
				allow_outside = yes
				alwaystransparent = yes
				visible = "[Or(Or(Not(GetVariableSystem.Exists('sakuya_tab')), GetVariableSystem.HasValue('sakuya_tab', 'character')), GetVariableSystem.Exists('sakuya_card_fade_transition'))]"

				state = {
					name = enter_subpage
					position = { 10 0 }
					duration = 0.33
					using = Animation_Curve_Default
				}

				state = {
					name = return_home
					position = { 55 0 }
					duration = 0.33
					using = Animation_Curve_Default
				}

				state = {
					name = fade_out_other
					alpha = 0
					duration = 0.25
					using = Animation_Curve_Default
					on_finish = "[GetVariableSystem.Clear('sakuya_card_fade_transition')]"
				}

				state = {
					name = restore_home
					alpha = 1
					duration = 0.25
					using = Animation_Curve_Default
				}

				icon = {
					name = "sakuya_guiname_main_p1_underlight"
					position = { -82 399 }
