							bezier = { 0 0 1 1 }
						}

						icon = {
							size = { 354 570 }
							texture = "gfx/interface/component_overlay/overlay_thin_frame.dds"
							color = { 1.00 0.82 0.48 1 }
						}
					}

					# Shine sweep layer removed

				}

				widget = {
