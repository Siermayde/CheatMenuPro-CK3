					color = { 1.00 0.85 0.50 0.8 }
					alpha = 0.01
					alwaystransparent = yes

					state = {
						name = show_hover
						duration = 0.35
						alpha = 0.36
						bezier = { 0 0 1 1 }
					}

					state = {
						name = hide_hover
						duration = 0.35
						alpha = 0.01
						bezier = { 0 0 1 1 }
					}
				}

