######################################################
# CK3 CMP - Main GUI Framework
# Current phase: GUI only. No gameplay effects.
######################################################

window = {
	name = "sakuya_guiname_main_window"
	parentanchor = center
	position = { 0 0 }
	size = { 1280 720 }
	movable = yes
	layer = windows_layer
	allow_outside = yes
	filter_mouse = all

	visible = "[GetVariableSystem.Exists('sakuya_main_visible')]"
	enabled = "[GetVariableSystem.Exists('sakuya_main_visible')]"

	using = Animation_ShowHide_Standard
	state = { name = _show alpha = 1 duration = 0.2 using = Animation_Curve_Default }
	state = { name = _hide alpha = 0 duration = 0.2 using = Animation_Curve_Default }

	widget = {
		name = "sakuya_guiname_main_root" 
		size = { 1280 720 }

		icon = {
			size = { 1280 720 }
			texture = "gfx/interface/sakuya/sakuya_background_family_blur.png"
		}

		icon = {
			position = { 20 18 }
			size = { 1240 684 }
			texture = "gfx/interface/component_overlay/overlay_thin_frame.dds"
			alpha = 0.78
		}

		textbox = {
			name = "sakuya_guiname_main_title"
			position = { 52 40 }
			size = { 620 52 }
			maximumsize = { 620 52 }
			text = "sakuya_main_title_text"
			fontsize = 36
			fontsize_min = 22
			autoresize = no
			align = left|nobaseline
			default_format = "#COLOR:{0.639,0.581,0.492,1};bold;glow_color:{0,0,0,0.85}"
		}

		button_standard = {
			name = "sakuya_guiname_main_return_button"
			parentanchor = top|right
			position = { -322 42 }
			size = { 150 38 }
			visible = "[GetVariableSystem.Exists('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_tab')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			tooltip = "sakuya_main_back_tt"
			text_single = {
				parentanchor = center
				text = "sakuya_main_back_text"
				fontsize = 16
				fontsize_min = 10
				autoresize = no
				align = center|nobaseline
			}
		}

		button_close = {
			name = "sakuya_guiname_main_close_button"
			parentanchor = top|right
			position = { -18 18 }
			size = { 30 30 }
			tooltip = "sakuya_main_close_tt"
			onclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_visible')]"
			onrightclick = "[GetVariableSystem.Clear('sakuya_main_hover')]"
			shortcut = "close_window"
		}

		widget = {
			name = "sakuya_guiname_main_home_cards"
			position = { 58 112 }
			size = { 1164 570 }
			allow_outside = yes
			visible = "[Not(GetVariableSystem.Exists('sakuya_tab'))]"

			widget = {
				name = "sakuya_guiname_main_p1_character_card"
				position = { 0 0 }
				size = { 354 570 }
				allow_outside = yes
				alwaystransparent = yes

				widget = {
					name = "sakuya_guiname_main_p1_character_clip"
					size = { 354 570 }
					scissor = yes
					alwaystransparent = yes

					widget = {
						name = "sakuya_guiname_main_p1_character_wallpaper"
						parentanchor = center
						widgetanchor = center
						size = { 354 570 }
						scale = 1.0
						allow_outside = yes
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.33
							scale = 1.1
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							scale = 1.0
							bezier = { 0 0 1 1 }
						}

						icon = {
							parentanchor = center
							widgetanchor = center
							size = { 1138 570 }
							texture = "gfx/interface/illustrations/activity_header_backgrounds/activity_adult_education.dds"
							color = { 1 1 1 1 }
						}
					}

					widget = {
						name = "sakuya_guiname_main_p1_character_dim"
						size = { 354 570 }
						alpha = 0.16
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.33
							alpha = 0.04
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							alpha = 0.16
							bezier = { 0 0 1 1 }
						}

						icon = { size = { 354 570 } texture = "gfx/interface/colors/black.dds" }
					}

					# VFX Layer 1: soft indoor window light
					icon = {
						name = "sakuya_guiname_main_p1_vfx_sunlight"
						size = { 420 570 }
						texture = "gfx/particles/window_sunlight_01.dds"
						color = { 1.00 0.90 0.74 0.14 }
						parentanchor = center
						position = { -34 0 }
						alpha = 0
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.5
							alpha = 0.42
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.5
							alpha = 0
							bezier = { 0 0 1 1 }
						}
					}

					# VFX Layer 2: low warm ambient glow
					icon = {
						name = "sakuya_guiname_main_p1_vfx_glow"
						size = { 354 570 }
						texture = "gfx/interface/component_masks/mask_glow.dds"
						color = { 1.00 0.78 0.48 0.10 }
						parentanchor = center
						alpha = 0
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.5
							alpha = 0.36
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							trigger_on_create = yes
							duration = 0.5
							alpha = 0
							bezier = { 0 0 1 1 }
						}
					}

					# VFX Layer 3: soft window pattern for the indoor scene
					icon = {
						name = "sakuya_guiname_main_p1_vfx_window_cookie"
						size = { 254 360 }
						texture = "gfx/particles/window_cookie_02.dds"
						color = { 1.00 0.88 0.68 0.16 }
						parentanchor = center
						widgetanchor = center
						position = { 60 -70 }
						alpha = 0
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.5
							alpha = 0.55
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							trigger_on_create = yes
							duration = 0.5
							alpha = 0
							bezier = { 0 0 1 1 }
						}
					}

					# VFX Layer: Earthquake foreground shader (hover visible, alpha 0.77)
					icon = {
						name = "sakuya_guiname_main_p1_vfx_earthquake"
						visible = "[GetVariableSystem.HasValue('sakuya_main_hover', 'character')]"
						size = { 354 570 }
						texture = "gfx/interface/window_vfx/noise_01.dds"
						gfxtype = icongfx
						effectname = "Earthquake"
						shaderfile = "gfx/FX/pdxgui_event_vfx.shader"
						mipmaplodbias = -1
						parentanchor = center
						alpha = 0
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.5
							alpha = 0.76
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							trigger_on_create = yes
							duration = 0.5
							alpha = 0
							bezier = { 0 0 1 1 }
						}

						activity_locale_vfx = {
							size = { 100% 100% }
							position = { 0.0% 0.0% }
							entity_instance = "ui_earthquake"
						}
					}

					widget = {
						name = "sakuya_guiname_main_p1_marked_character_portrait_static"
						datacontext = "[GetGlobalVariable('sakuya_marked_character').Char]"
						visible = "[And(GetGlobalVariable('sakuya_marked_character').IsSet, Not(GetVariableSystem.HasValue('sakuya_main_hover', 'character')))]"
						parentanchor = center
						widgetanchor = center
						position = { 0 40 }
						size = { 308 396 }
						alpha = 0.98
						allow_outside = no

						state = {
							name = show_hover
							duration = 0.33
							alpha = 1.0
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							alpha = 0.98
							bezier = { 0 0 1 1 }
						}

						portrait_body_large = {
							parentanchor = bottom|hcenter
							scale = 0.88
							size = { 308 396 }
							blockoverride "status_icons" {}
							blockoverride "coa" {}
							blockoverride "opinion_box" {}
							blockoverride "portrait_texture" {
								portrait_texture = "[Character.GetPortrait('environment_event_study', 'camera_body', 'idle', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
							}
						}
					}

					widget = {
						name = "sakuya_guiname_main_p1_marked_character_portrait_animated"
						datacontext = "[GetGlobalVariable('sakuya_marked_character').Char]"
						visible = "[And(GetGlobalVariable('sakuya_marked_character').IsSet, GetVariableSystem.HasValue('sakuya_main_hover', 'character'))]"
						parentanchor = center
						widgetanchor = center
						position = { 0 40 }
						size = { 308 396 }
						alpha = 0.98
						allow_outside = no

						state = {
							name = show_hover
							duration = 0.33
							alpha = 1.0
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							alpha = 0.98
							bezier = { 0 0 1 1 }
						}

						portrait_body_large = {
							parentanchor = bottom|hcenter
							scale = 0.88
							size = { 308 396 }
							blockoverride "status_icons" {}
							blockoverride "coa" {}
							blockoverride "opinion_box" {}
							blockoverride "portrait_texture" {
								portrait_texture = "[Character.GetAnimatedPortrait('environment_event_study', 'camera_body', 'idle', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
							}
						}
					}

					widget = {
						name = "sakuya_guiname_main_p1_character_portrait_static"
						datacontext = "[GetPlayer]"
						visible = "[And(And(GetPlayer.IsValid, Not(GetGlobalVariable('sakuya_marked_character').IsSet)), Not(GetVariableSystem.HasValue('sakuya_main_hover', 'character')))]"
						parentanchor = center
						widgetanchor = center
						position = { 0 40 }
						size = { 308 396 }
						alpha = 0.98
						allow_outside = no

						state = {
							name = show_hover
							duration = 0.33
							alpha = 1.0
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							alpha = 0.98
							bezier = { 0 0 1 1 }
						}

						portrait_body_large = {
							parentanchor = bottom|hcenter
							scale = 0.88
							size = { 308 396 }
							blockoverride "status_icons" {}
							blockoverride "coa" {}
							blockoverride "opinion_box" {}
							blockoverride "portrait_texture" {
								portrait_texture = "[Character.GetPortrait('environment_event_study', 'camera_body', 'idle', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
							}
						}
					}

					widget = {
						name = "sakuya_guiname_main_p1_character_portrait_animated"
						datacontext = "[GetPlayer]"
						visible = "[And(And(GetPlayer.IsValid, Not(GetGlobalVariable('sakuya_marked_character').IsSet)), GetVariableSystem.HasValue('sakuya_main_hover', 'character'))]"
						parentanchor = center
						widgetanchor = center
						position = { 0 40 }
						size = { 308 396 }
						alpha = 0.98
						allow_outside = no

						state = {
							name = show_hover
							duration = 0.33
							alpha = 1.0
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
							alpha = 0.98
							bezier = { 0 0 1 1 }
						}

						portrait_body_large = {
							parentanchor = bottom|hcenter
							scale = 0.88
							size = { 308 396 }
							blockoverride "status_icons" {}
							blockoverride "coa" {}
							blockoverride "opinion_box" {}
							blockoverride "portrait_texture" {
								portrait_texture = "[Character.GetAnimatedPortrait('environment_event_study', 'camera_body', 'idle', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
							}
						}
					}



					widget = {
						name = "sakuya_guiname_main_p1_character_border_glow"
						size = { 354 570 }
						alpha = 0
						alwaystransparent = yes

						state = {
							name = show_hover
							duration = 0.33
							alpha = 1
							bezier = { 0 0 1 1 }
						}

						state = {
							name = hide_hover
							duration = 0.33
