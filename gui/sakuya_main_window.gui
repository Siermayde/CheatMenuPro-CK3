				onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_bright').InterruptThenTriggerAnimation('show_hover','hide_hover')]"
				onclick = "[PdxGuiWidget.AccessParent.FindChild('sakuya_guiname_main_p1_character_border_glow').InterruptThenTriggerAnimation('show_hover','hide_hover')]"
